### Step 13 (Mode B) — Submit for review + clean up

> The old `POST /v1/appStoreVersionSubmissions` endpoint is **deprecated** (removed in ASC API 1.7).
> **Never** use it — it returns 403 FORBIDDEN_ERROR.
>
> Use the new `reviewSubmissions` flow:
>   **13-pre.** Cancel ALL existing in-progress submissions and remove our version from any stale submission
>   **13a.** Create a fresh review submission
>   **13b.** Add the App Store version as a review submission item
>   **13c.** PATCH the submission with `submitted: true` to trigger review

```bash
# -- Step 13-pre: Clear ALL blocking review submissions --
echo "Step 13-pre: Clearing any blocking review submissions..."

ALL_SUBS=$(curl -s \
  -H "Authorization: Bearer $JWT" \
  "https://api.appstoreconnect.apple.com/v1/apps/$APP_ID/reviewSubmissions")

BLOCKING_SUBS=$(echo "$ALL_SUBS" | python3 -c "
import sys, json
data = json.load(sys.stdin).get('data', [])
blocking = {'READY_FOR_REVIEW', 'WAITING_FOR_REVIEW', 'IN_REVIEW', 'UNRESOLVED_ISSUES'}
for s in data:
    state = s['attributes']['state']
    if state in blocking:
        print(s['id'], state)
" 2>/dev/null)

CANCELED_COUNT=0
if [ -n "$BLOCKING_SUBS" ]; then
  echo "$BLOCKING_SUBS" | while read SUB_ID SUB_STATE; do
    echo "  Found blocking submission $SUB_ID (state: $SUB_STATE) — canceling..."

    ITEMS_RESP=$(curl -s \
      -H "Authorization: Bearer $JWT" \
      "https://api.appstoreconnect.apple.com/v1/reviewSubmissions/$SUB_ID/items")

    ITEM_IDS_TO_REMOVE=$(echo "$ITEMS_RESP" | python3 -c "
import sys, json
data = json.load(sys.stdin).get('data', [])
version_id = '$VERSION_ID'
for item in data:
    rels = item.get('relationships', {})
    asv = rels.get('appStoreVersion', {}).get('data', {})
    if asv.get('id') == version_id:
        print(item['id'])
" 2>/dev/null)

    if [ -n "$ITEM_IDS_TO_REMOVE" ]; then
      for ITEM_ID in $ITEM_IDS_TO_REMOVE; do
        echo "    Removing version item $ITEM_ID from submission $SUB_ID..."
        DEL_RESP=$(curl -s -w "\n%{http_code}" -X DELETE \
          -H "Authorization: Bearer $JWT" \
          "https://api.appstoreconnect.apple.com/v1/reviewSubmissionItems/$ITEM_ID")
        DEL_HTTP=$(echo "$DEL_RESP" | tail -1)
        echo "    DELETE /v1/reviewSubmissionItems/$ITEM_ID -> HTTP $DEL_HTTP"
      done
    fi

    CANCEL_RESP=$(curl -s -w "\n%{http_code}" -X PATCH \
      -H "Authorization: Bearer $JWT" \
      -H "Content-Type: application/json" \
      -d "{\"data\":{\"id\":\"$SUB_ID\",\"type\":\"reviewSubmissions\",\"attributes\":{\"canceled\":true}}}" \
      "https://api.appstoreconnect.apple.com/v1/reviewSubmissions/$SUB_ID")
    CANCEL_HTTP=$(echo "$CANCEL_RESP" | tail -1)
    CANCEL_BODY=$(echo "$CANCEL_RESP" | sed '$d')
    echo "    PATCH /v1/reviewSubmissions/$SUB_ID {canceled:true} -> HTTP $CANCEL_HTTP"
    if [ "$CANCEL_HTTP" = "200" ]; then
      echo "    Submission $SUB_ID canceled"
    elif [ "$CANCEL_HTTP" = "409" ]; then
      echo "    Submission $SUB_ID returned 409 on cancel (already transitioning or completed)"
    else
      echo "    Unexpected HTTP $CANCEL_HTTP on cancel — continuing"
    fi
  done

  echo "  Waiting for cancellations to settle..."
  for i in $(seq 1 12); do
    sleep 5
    STILL_BLOCKING=$(curl -s \
      -H "Authorization: Bearer $JWT" \
      "https://api.appstoreconnect.apple.com/v1/apps/$APP_ID/reviewSubmissions" \
      | python3 -c "
import sys, json
data = json.load(sys.stdin).get('data', [])
blocking = {'READY_FOR_REVIEW', 'WAITING_FOR_REVIEW', 'IN_REVIEW', 'UNRESOLVED_ISSUES', 'CANCELING'}
count = sum(1 for s in data if s['attributes']['state'] in blocking)
print(count)
" 2>/dev/null)
    if [ "$STILL_BLOCKING" = "0" ] || [ -z "$STILL_BLOCKING" ]; then
      echo "  All blocking submissions cleared (~$((i * 5))s)"
      break
    fi
    echo "  Still $STILL_BLOCKING blocking submissions (~$((i * 5))s)..."
    if [ "$i" = "12" ]; then
      echo "  Timed out waiting for submissions to clear after 60s — proceeding anyway"
    fi
  done
else
  echo "  No blocking submissions found"
fi

NEW_VS=$(curl -s \
  -H "Authorization: Bearer $JWT" \
  "https://api.appstoreconnect.apple.com/v1/appStoreVersions/$VERSION_ID" \
  | python3 -c "
import sys, json
d = json.load(sys.stdin).get('data', {})
attrs = d.get('attributes', {})
print(attrs.get('appStoreState', '') or attrs.get('appVersionState', ''))
" 2>/dev/null)
echo "  Version state after pre-cleanup: $NEW_VS"

# -- Step 13a: Create a FRESH review submission --
echo "Step 13a: Creating new review submission..."

CREATE_SUB_RESP=$(curl -s -w "\n%{http_code}" -X POST \
  -H "Authorization: Bearer $JWT" \
  -H "Content-Type: application/json" \
  -d "{\"data\":{\"type\":\"reviewSubmissions\",\"relationships\":{\"app\":{\"data\":{\"id\":\"$APP_ID\",\"type\":\"apps\"}}}}}" \
  "https://api.appstoreconnect.apple.com/v1/reviewSubmissions")

CREATE_SUB_HTTP=$(echo "$CREATE_SUB_RESP" | tail -1)
CREATE_SUB_BODY=$(echo "$CREATE_SUB_RESP" | sed '$d')

echo "Request:"
echo "  POST https://api.appstoreconnect.apple.com/v1/reviewSubmissions"
echo "  Body: {\"data\":{\"type\":\"reviewSubmissions\",\"relationships\":{\"app\":{\"data\":{\"id\":\"$APP_ID\",\"type\":\"apps\"}}}}}"
echo "Response HTTP: $CREATE_SUB_HTTP"
echo "Response Body: $CREATE_SUB_BODY"

if [ "$CREATE_SUB_HTTP" = "201" ]; then
  REVIEW_SUBMISSION_ID=$(echo "$CREATE_SUB_BODY" | python3 -c "import sys,json; print(json.load(sys.stdin)['data']['id'])" 2>/dev/null)
  echo "Review submission created (ID: $REVIEW_SUBMISSION_ID)"
elif [ "$CREATE_SUB_HTTP" = "409" ]; then
  echo "Create returned 409 — looking for a reusable existing submission..."
  REUSE_SUBS=$(curl -s \
    -H "Authorization: Bearer $JWT" \
    "https://api.appstoreconnect.apple.com/v1/apps/$APP_ID/reviewSubmissions")
  REVIEW_SUBMISSION_ID=$(echo "$REUSE_SUBS" | python3 -c "
import sys, json
data = json.load(sys.stdin).get('data', [])
for s in data:
    if s['attributes']['state'] == 'READY_FOR_REVIEW':
        print(s['id'])
        break
" 2>/dev/null)
  if [ -n "$REVIEW_SUBMISSION_ID" ]; then
    echo "Reusing existing READY_FOR_REVIEW submission (ID: $REVIEW_SUBMISSION_ID)"
  else
    rm -f /tmp/AuthKey_${KEY_ID}.p8
    echo "Step 13a failed — 409 on create and no READY_FOR_REVIEW submission found."
    echo "   Check App Store Connect manually for stuck submissions."
    exit 1
  fi
else
  rm -f /tmp/AuthKey_${KEY_ID}.p8
  echo "Step 13a failed — could not create review submission (HTTP $CREATE_SUB_HTTP): $CREATE_SUB_BODY"
  exit 1
fi

# -- Step 13b: Add App Store version as item --
echo "Step 13b: Adding App Store version to review submission..."
ADD_ITEM_RESP=$(curl -s -w "\n%{http_code}" -X POST \
  -H "Authorization: Bearer $JWT" \
  -H "Content-Type: application/json" \
  -d "{\"data\":{\"type\":\"reviewSubmissionItems\",\"relationships\":{\"reviewSubmission\":{\"data\":{\"id\":\"$REVIEW_SUBMISSION_ID\",\"type\":\"reviewSubmissions\"}},\"appStoreVersion\":{\"data\":{\"id\":\"$VERSION_ID\",\"type\":\"appStoreVersions\"}}}}}" \
  "https://api.appstoreconnect.apple.com/v1/reviewSubmissionItems")

ADD_ITEM_HTTP=$(echo "$ADD_ITEM_RESP" | tail -1)
ADD_ITEM_BODY=$(echo "$ADD_ITEM_RESP" | sed '$d')

echo "Request:"
echo "  POST https://api.appstoreconnect.apple.com/v1/reviewSubmissionItems"
echo "Response HTTP: $ADD_ITEM_HTTP"
echo "Response Body: $ADD_ITEM_BODY"

if [ "$ADD_ITEM_HTTP" = "201" ]; then
  echo "App Store version added to review submission"
elif [ "$ADD_ITEM_HTTP" = "409" ]; then
  IS_ANOTHER=$(echo "$ADD_ITEM_BODY" | python3 -c "
import sys, json
try:
    errors = json.load(sys.stdin).get('errors', [])
    for e in errors:
        detail = e.get('detail', '')
        if 'another' in detail.lower() or 'ITEM_PART_OF_ANOTHER' in e.get('code', ''):
            print('yes')
            break
except: pass
" 2>/dev/null)

  if [ "$IS_ANOTHER" = "yes" ]; then
    echo "Version is still in another submission — attempting cleanup..."
    FIND_SUBS=$(curl -s \
      -H "Authorization: Bearer $JWT" \
      "https://api.appstoreconnect.apple.com/v1/apps/$APP_ID/reviewSubmissions")
    OTHER_SUB_IDS=$(echo "$FIND_SUBS" | python3 -c "
import sys, json
data = json.load(sys.stdin).get('data', [])
my_sub = '$REVIEW_SUBMISSION_ID'
active = {'READY_FOR_REVIEW', 'WAITING_FOR_REVIEW', 'IN_REVIEW', 'UNRESOLVED_ISSUES', 'COMPLETING'}
for s in data:
    if s['id'] != my_sub and s['attributes']['state'] in active:
        print(s['id'], s['attributes']['state'])
" 2>/dev/null)
    echo "$OTHER_SUB_IDS" | while read OTHER_ID OTHER_STATE; do
      [ -z "$OTHER_ID" ] && continue
      echo "  Canceling other submission $OTHER_ID ($OTHER_STATE)..."
      curl -s -X PATCH \
        -H "Authorization: Bearer $JWT" \
        -H "Content-Type: application/json" \
        -d "{\"data\":{\"id\":\"$OTHER_ID\",\"type\":\"reviewSubmissions\",\"attributes\":{\"canceled\":true}}}" \
        "https://api.appstoreconnect.apple.com/v1/reviewSubmissions/$OTHER_ID" > /dev/null 2>&1
    done
    sleep 10

    echo "  Retrying add item..."
    ADD_ITEM_RESP2=$(curl -s -w "\n%{http_code}" -X POST \
      -H "Authorization: Bearer $JWT" \
      -H "Content-Type: application/json" \
      -d "{\"data\":{\"type\":\"reviewSubmissionItems\",\"relationships\":{\"reviewSubmission\":{\"data\":{\"id\":\"$REVIEW_SUBMISSION_ID\",\"type\":\"reviewSubmissions\"}},\"appStoreVersion\":{\"data\":{\"id\":\"$VERSION_ID\",\"type\":\"appStoreVersions\"}}}}}" \
      "https://api.appstoreconnect.apple.com/v1/reviewSubmissionItems")
    ADD_ITEM_HTTP2=$(echo "$ADD_ITEM_RESP2" | tail -1)
    if [ "$ADD_ITEM_HTTP2" = "201" ]; then
      echo "  App Store version added on retry"
    elif [ "$ADD_ITEM_HTTP2" = "409" ]; then
      echo "  Still 409 on retry — version may already be in our submission (continuing)"
    else
      echo "  Retry failed HTTP $ADD_ITEM_HTTP2"
    fi
  else
    echo "Version already part of this submission (409) — continuing to Step 13c"
  fi
else
  rm -f /tmp/AuthKey_${KEY_ID}.p8
  echo "Step 13b failed (HTTP $ADD_ITEM_HTTP): $ADD_ITEM_BODY"
  exit 1
fi

# -- Step 13c: Submit for review (PATCH submitted=true) --
echo "Step 13c: Submitting for review..."
SUBMIT_SUCCESS="false"
for submit_attempt in 1 2 3; do
  SUBMIT_RESP=$(curl -s -w "\n%{http_code}" -X PATCH \
    -H "Authorization: Bearer $JWT" \
    -H "Content-Type: application/json" \
    -d "{\"data\":{\"id\":\"$REVIEW_SUBMISSION_ID\",\"type\":\"reviewSubmissions\",\"attributes\":{\"submitted\":true}}}" \
    "https://api.appstoreconnect.apple.com/v1/reviewSubmissions/$REVIEW_SUBMISSION_ID")

  HTTP=$(echo "$SUBMIT_RESP" | tail -1)
  BODY=$(echo "$SUBMIT_RESP" | sed '$d')

  echo "Request (attempt $submit_attempt/3):"
  echo "  PATCH https://api.appstoreconnect.apple.com/v1/reviewSubmissions/$REVIEW_SUBMISSION_ID"
  echo "  Body: {\"data\":{\"id\":\"$REVIEW_SUBMISSION_ID\",\"type\":\"reviewSubmissions\",\"attributes\":{\"submitted\":true}}}"
  echo "Response HTTP: $HTTP"
  echo "Response Body: $BODY"

  if [ "$HTTP" = "200" ]; then
    echo "Submitted for review — Waiting for Review"
    SUBMIT_SUCCESS="true"
    break
  elif [ "$HTTP" = "409" ] && [ "$submit_attempt" -lt 3 ]; then
    echo "  409 conflict — ASC may still be processing. Waiting 15s before retry..."
    sleep 15
    continue
  elif [ "$HTTP" = "403" ]; then
    echo "Submit failed 403 — API key needs App Manager or Admin role in App Store Connect."
    echo "   Go to Users & Access -> API Keys -> verify this key has App Manager or Admin role."
    echo "   All prior steps succeeded. Submit manually in App Store Connect if needed."
    break
  elif [ "$HTTP" = "409" ]; then
    echo "Submit failed 409 after 3 attempts — Version may not be ready to be submitted."
    echo "   Common causes: build still processing, missing required metadata/screenshots."
    echo "   Check App Store Connect for the current status of this version."
    break
  else
    echo "Submit failed (HTTP $HTTP): $BODY"
    echo "   Common cause: missing screenshots or required metadata on the version."
    echo "   Fix in App Store Connect, then re-trigger or submit manually."
    break
  fi
done

rm -f /tmp/AuthKey_${KEY_ID}.p8
```

